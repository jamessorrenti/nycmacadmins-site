{{- /* Events RSS feed. Rendered for the events section at /events/index.xml.
     Items: every published event, newest first. pubDate = event start. */ -}}
{{- printf "<?xml version=\"1.0\" encoding=\"utf-8\" standalone=\"yes\"?>" | safeHTML }}
<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom">
  <channel>
    <title>NYC Mac Admins Events</title>
    <link>{{ site.Home.Permalink }}</link>
    <description>Meetup announcements from NYC Mac Admins — dates, venues, presentations, and sign-up links.</description>
    <language>en-us</language>
    <managingEditor>{{ site.Params.email }} (NYC Mac Admins)</managingEditor>
    <lastBuildDate>{{ now.Format "Mon, 02 Jan 2006 15:04:05 -0700" }}</lastBuildDate>
    <atom:link href="{{ .Permalink }}index.xml" rel="self" type="application/rss+xml" />
    {{- $events := sort (where site.RegularPages "Section" "events") "Date" "desc" }}
    {{- range first 50 $events }}
    <item>
      <title>{{ .Title }}</title>
      <link>{{ .Permalink }}</link>
      <guid>{{ .Permalink }}</guid>
      <pubDate>{{ .Date.Format "Mon, 02 Jan 2006 15:04:05 -0700" }}</pubDate>
      <description>{{ partial "event-rss-description.html" . | html }}</description>
    </item>
    {{- end }}
  </channel>
</rss>
